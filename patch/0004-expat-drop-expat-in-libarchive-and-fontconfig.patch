From 45c53b95a0f997eb341a04daa8a5fbd5344f0a17 Mon Sep 17 00:00:00 2001
From: zhongfly <11155705+zhongfly@users.noreply.github.com>
Date: Wed, 13 May 2026 22:03:25 +0800
Subject: [PATCH 1/6] expat: drop expat in libarchive and fontconfig

---
 packages/CMakeLists.txt   | 2 +-
 packages/fontconfig.cmake | 3 ++-
 packages/libarchive.cmake | 3 +--
 3 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/packages/CMakeLists.txt b/packages/CMakeLists.txt
index c2c0ecc..9a6b511 100644
--- a/packages/CMakeLists.txt
+++ b/packages/CMakeLists.txt
@@ -119,7 +119,7 @@ list(LENGTH ep ep_length)
 message(STATUS "Parsing ${ep_length} packages")
 
 # Exclude packages which dont depend on mpv when update
-list(APPEND removed "flac" "opusfile" "libopusenc" "opus-tools" "termcap" "readline" "cryptopp" "sqlite" "libuv" "libsodium" "megasdk" "libsixel" "curl" "libressl" "mbedtls" "nettle" "gmp" "xvidcore")
+list(APPEND removed "flac" "opusfile" "libopusenc" "opus-tools" "termcap" "readline" "cryptopp" "sqlite" "libuv" "libsodium" "megasdk" "libsixel" "curl" "libressl" "mbedtls" "nettle" "gmp" "xvidcore" "expat")
 list(REMOVE_ITEM repo ${removed})
 list(REMOVE_ITEM ep ${removed})
 list(TRANSFORM repo APPEND "-force-update" OUTPUT_VARIABLE update)
diff --git a/packages/fontconfig.cmake b/packages/fontconfig.cmake
index 2d322a9..fcaf791 100644
--- a/packages/fontconfig.cmake
+++ b/packages/fontconfig.cmake
@@ -1,6 +1,6 @@
 ExternalProject_Add(fontconfig
     DEPENDS
-        expat
+        libxml2
         freetype2
         zlib
         libiconv
@@ -23,6 +23,7 @@ ExternalProject_Add(fontconfig
         -Dtests=disabled
         -Dtools=disabled
         -Dcache-build=disabled
+        -Dxml-backend=libxml2
     BUILD_COMMAND ${EXEC} ninja -C <BINARY_DIR>
     INSTALL_COMMAND ${EXEC} ninja -C <BINARY_DIR> install
     LOG_DOWNLOAD 1 LOG_UPDATE 1 LOG_CONFIGURE 1 LOG_BUILD 1 LOG_INSTALL 1
diff --git a/packages/libarchive.cmake b/packages/libarchive.cmake
index ef23ed7..39f0396 100644
--- a/packages/libarchive.cmake
+++ b/packages/libarchive.cmake
@@ -1,7 +1,6 @@
 ExternalProject_Add(libarchive
     DEPENDS
         bzip2
-        expat
         lzo
         xz
         zlib
@@ -26,7 +25,7 @@ ExternalProject_Add(libarchive
         -DENABLE_BZip2=ON
         -DENABLE_ICONV=ON
         -DENABLE_LIBXML2=ON
-        -DENABLE_EXPAT=ON
+        -DENABLE_EXPAT=OFF
         -DENABLE_LZO=ON
         -DENABLE_LZMA=ON
         -DENABLE_CPIO=OFF
-- 
2.52.0.windows.1

