 packages/xz.cmake | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/packages/xz.cmake b/packages/xz.cmake
index 670e691d1..1d06de285 100644
--- a/packages/xz.cmake
+++ b/packages/xz.cmake
@@ -1,9 +1,9 @@
 ExternalProject_Add(xz
